# ============================================================
# CopilotLiteLLM Deployment Configuration
# ============================================================
# Copy this file to config.env and customize the values below.
# All scripts source this file for shared settings.
# ============================================================

# --- Azure Resource Settings ---
RESOURCE_GROUP="rg-litellm-proxy"
LOCATION="eastus"
CONTAINER_APP_NAME="litellm-proxy"
CONTAINER_APP_ENV="litellm-env"
STORAGE_ACCOUNT_NAME="stlitellmproxy"       # Must be globally unique, lowercase, 3-24 chars
FILE_SHARE_NAME="litellm-config"

# --- LiteLLM Settings ---
LITELLM_IMAGE="ghcr.io/berriai/litellm:main-v1.81.0-patch3"
LITELLM_PORT=4000
CONTAINER_CPU="1.0"
CONTAINER_MEMORY="2.0Gi"

# --- Docker Volume (used during local auth) ---
DOCKER_VOLUME_NAME="litellm_config"

# --- PostgreSQL (OPTIONAL — only needed for Admin UI dashboard) ---
# Skip this if you only need the proxy API without the web dashboard.
PG_LOCATION="centralus"                     # Some regions restrict PG Flexible Server, try centralus/westeurope
PG_ADMIN_USER="litellmadmin"
# PG_PASSWORD=""                            # Auto-generated at deploy time

# --- Generated at deploy time (leave empty to auto-generate) ---
# LITELLM_API_KEY=""
